# BugHunt.ai Environment Configuration
# Copy this to .env and fill in your values
# Then: source .env

# Groq API Key (get from https://console.groq.com)
export GROQ_API_KEY="your-groq-api-key-here"

# Optional: Timeout for tool execution (seconds)
export TOOL_TIMEOUT="120"

# Optional: Number of parallel tests. Keep low for strict bug bounty programs.
export PARALLEL_TESTS="4"

# Optional: Random delay range between internal HTTP requests
export BUGHUNT_DELAY_MIN="0.8"
export BUGHUNT_DELAY_MAX="2.5"

# Optional: Archive URL provider timeout in seconds
export ARCHIVE_TIMEOUT="45"

# Optional: Bug bounty program approved User-Agent
# You can leave this unset and paste it when the hunt starts.
# export BUGHUNT_USER_AGENT="bug-bounty-jojin1709 contact: your-email@example.com"

# Optional: Program-required custom HTTP header
# export BUGHUNT_HEADER="X-HackerOne-Research: your-h1-username"

# Optional: Authenticated testing with your own test account/session only
# export BUGHUNT_COOKIE="session=your-own-session-cookie"
# export BUGHUNT_AUTHORIZATION="Bearer your-own-token"

# Optional: Private local program rules for Groq planning
# export BUGHUNT_PROGRAM_RULES_FILE="program_rules.txt"

# Optional: Proxy (if needed)
# export HTTP_PROXY="http://proxy:8080"
# export HTTPS_PROXY="http://proxy:8080"

# Load this file before running:
# source .env
# python3 bughunt_groq.py hunt target.com
