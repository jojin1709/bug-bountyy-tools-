# BugHunt.ai Environment Configuration
# Copy this to .env and fill in your values
# Then: source .env

# Groq API Key (get from https://console.groq.com)
export GROQ_API_KEY="your-groq-api-key-here"

# Optional: Timeout for tool execution (seconds)
export TOOL_TIMEOUT="120"

# Optional: Number of parallel tests
export PARALLEL_TESTS="10"

# Optional: Archive URL provider timeout in seconds
export ARCHIVE_TIMEOUT="45"

# Optional: Bug bounty program approved User-Agent
# export BUGHUNT_USER_AGENT="bug-bounty-jojin1709 contact: your-email@example.com"

# Optional: Proxy (if needed)
# export HTTP_PROXY="http://proxy:8080"
# export HTTPS_PROXY="http://proxy:8080"

# Load this file before running:
# source .env
# python3 bughunt_groq.py hunt target.com
